  <!ELEMENT sub_stats (#PCDATA)>
  <!ELEMENT bangboos (bangboo+)>
  <!ELEMENT bangboo (nombre, rareza, habilidad, imagen_boo)>
  <!ATTLIST bangboo id_agente IDREF #REQUIRED>
  <!ELEMENT rareza (#PCDATA)>
  <!ELEMENT habilidad (#PCDATA)>
  <!ELEMENT imagen_boo (#PCDATA)>
  <!ELEMENT equipos (equipo+)>
  <!ELEMENT equipo (comp, motivo)>
  <!ATTLIST equipo id_agente IDREF #REQUIRED>
  <!ELEMENT comp (#PCDATA)>
  <!ELEMENT motivo (#PCDATA)>
  <!ELEMENT habilidades_lista (skills+)>
  <!ELEMENT skills (orden)>
